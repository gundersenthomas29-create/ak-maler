{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ak-maler",
  "compatibility_date": "2026-06-19",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/server/server.js",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  },
  "observability": { "enabled": true }
}
